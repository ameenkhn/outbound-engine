# Copy to .env.local and fill with FRESH (rotated) values. Never commit .env.local.
# The Vercel token / AI-gateway key pasted in chat earlier are compromised — rotate them.

# Supabase (project cwxqdcomhvuijwmvkbuu). Anon key is public-safe (client).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service-role key — SERVER ONLY. Never expose to the browser, never prefix NEXT_PUBLIC_.
# Used by server components / server actions to read+write past RLS for the ops console.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# (Later, for streaming Mode A chat in the browser via Vercel AI Gateway — not used in v1)
# AI_GATEWAY_API_KEY=YOUR-ROTATED-VERCEL-AI-GATEWAY-KEY
