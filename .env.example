# Copy to .env and fill in. Loaded automatically by data/db.py (python-dotenv).

# L0 Lead DB — Postgres connection string.
# Local dev (quick start):  docker run --rm -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:dev@localhost:5432/exly_outbound

# ---------------------------------------------------------------------------
# Meta Ad Library scraper hardening (sourcing/meta_ads). All optional — unset
# values fall back to historical defaults (direct connection, concurrency 2).
# ---------------------------------------------------------------------------

# Rotating outbound proxies. Comma-separated proxy server URLs; inline
# user:pass credentials are supported. Empty/unset => run direct (default).
#   SCRAPER_PROXIES=http://user:pass@proxy1.example.com:8080,http://proxy2.example.com:3128
SCRAPER_PROXIES=

# Concurrent advertiser-page visits (default 2; was hardcoded 4).
SCRAPER_CONCURRENCY=2

# Retry / backoff tuning for blocked or empty queries (exponential + jitter).
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_BASE=1.0
SCRAPER_BACKOFF_MAX=60.0

# Log verbosity for the scraper's structured logger (DEBUG/INFO/WARNING/ERROR).
SCRAPER_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Instagram source adapter (sourcing/instagram). Provider-agnostic: point it at
# whichever Instagram search/enrichment API you use (Apify, RapidAPI, etc.).
# Unset => the adapter only works with an injected client (e.g. tests).
# ---------------------------------------------------------------------------
#   INSTAGRAM_API_BASE=https://your-provider.example.com/instagram
#   INSTAGRAM_API_KEY=your_provider_key
INSTAGRAM_API_BASE=
INSTAGRAM_API_KEY=

# ---------------------------------------------------------------------------
# LinkedIn source adapter (sourcing/linkedin). Sourcing/enrichment ONLY — no
# automated DMs. Provider-agnostic, same shape as the Instagram client.
# ---------------------------------------------------------------------------
#   LINKEDIN_API_BASE=https://your-provider.example.com/linkedin
#   LINKEDIN_API_KEY=your_provider_key
LINKEDIN_API_BASE=
LINKEDIN_API_KEY=

# ---------------------------------------------------------------------------
# YouTube source adapter (sourcing/youtube) — official Data API v3 key.
# ---------------------------------------------------------------------------
YOUTUBE_API_KEY=

# ---------------------------------------------------------------------------
# Web-search source adapter (sourcing/websearch). Provider-agnostic: point it at
# a search API (Serper, SerpAPI, Bing, etc.) that returns title/url/snippet.
# ---------------------------------------------------------------------------
#   WEBSEARCH_API_BASE=https://your-search-provider.example.com
#   WEBSEARCH_API_KEY=your_provider_key
WEBSEARCH_API_BASE=
WEBSEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Shared HTTP robustness for the provider-backed adapters (sourcing/_http.py).
# All optional; defaults shown. SCRAPER_PROXIES (above) is reused for outbound
# proxy rotation across Instagram / LinkedIn / web-search clients too.
# ---------------------------------------------------------------------------
SOURCING_MAX_RETRIES=3
SOURCING_BACKOFF_BASE=1.0
SOURCING_BACKOFF_MAX=30.0
